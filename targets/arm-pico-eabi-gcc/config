CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="/opt/x-tools/arm-pico-eabi-gcc"
CT_ALIAS="arm-pico-eabi-gcc"
CT_TARGET_VENDOR="pico"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARM=y
CT_ARCH_ARCH="cortex-m0plus"
CT_ARCH_32=y
# CT_ARCH_64 is not set
CT_ARCH_FLOAT_SOFTFP=y
CT_BARE_METAL=y
CT_KERNEL_BARE_METAL=y	
CT_BINUTILS_PLUGINS=y
CT_LIBC_PICOLIBC=y
CT_PICOLIBC_V_1_8=y
CT_CC_LANG_CXX=y
# CT_LINKER_MOLD is not set
CT_GCC_V_15=y
# CT_CC_GCC_ENABLE_DEFAULT_PIE is not set
CT_BINUTILS_V_2_46=y
CT_TOOLCHAIN_PKGVERSION="Raspberry Pi"
CT_TARGET_CFLAGS="-mthumb"
CT_TARGET_CFLAGS="-O2 -pipe -mthumb"
