CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="/opt/x-tools/${CT_TARGET}"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARM=y
# CT_ARCH_ARCH is not set
CT_ARCH_CPU="cortex-a53"
CT_ARCH_TUNE="armv6zk"
CT_ARCH_32=y
CT_ARCH_SUFFIX="v8"
CT_ARCH_FPU="neon-fp-armv8"
CT_ARCH_FLOAT_HW=y
# CT_ARCH_FLOAT_SOFTFP is not set
# CT_ARCH_FLOAT_SW is not set
CT_ARCH_FLOAT="hard"
CT_TARGET_VENDOR="linaro"
CT_KERNEL_LINUX=y
CT_LINUX_V_6_18=y
CT_BINUTILS_PLUGINS=y
CT_BINUTILS_FOR_TARGET=y
CT_BINUTILS_V_2_38=y
CT_BINUTILS_GOLD_SUPPORTS_ARCH=y
CT_BINUTILS_HAS_GOLD=y
CT_BINUTILS_GOLD_SUPPORT=y
CT_BINUTILS_LINKER_LD_GOLD=y
CT_BINUTILS_GOLD_INSTALLED=y
CT_BINUTILS_GOLD_THREADS=y
CT_BINUTILS_LINKER_BOTH=y
CT_BINUTILS_LINKERS_LIST="ld,gold"
# CT_BINUTILS_LD_WRAPPER is not set
CT_LIBC_MUSL=y
CT_MUSL_V_1_2_6=y
CT_GCC_USE_LINARO=y
CT_CC_LANG_CXX=y
CT_TOOLCHAIN_PKGVERSION="Linaro"
CT_TARGET_CFLAGS="-O2 -pipe -ftree-vectorize -fomit-frame-pointer -ffunction-sections -fdata-sections -mfloat-abi=hard"
CT_TARGET_LDFLAGS="-Wl,--gc-sections -Wl,-O1 -Wl,--as-needed -s -w"
