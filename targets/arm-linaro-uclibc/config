CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_TARGET_ALIAS="arm-linaro-uclibc"
CT_PREFIX_DIR="/opt/x-tools/${CT_TARGET_ALIAS}"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARM=y
# CT_ARCH_ARCH is not set
CT_ARCH_CPU="cortex-a7"
CT_ARCH_TUNE="armv6zk"
CT_ARCH_32=y
# CT_ARCH_SUFFIX is not set
# CT_ARCH_ARM_TUPLE_USE_EABIHF is not set
CT_ARCH_FPU="neon-vfpv4"
CT_ARCH_FLOAT_HW=y
CT_ARCH_FLOAT="hard"
CT_TARGET_VENDOR="linaro"
CT_KERNEL_LINUX=y
CT_LINUX_V_6_18=y
CT_BINUTILS_PLUGINS=y
CT_BINUTILS_V_2_46=y
CT_LINKER_MOLD=y
CT_LIBC_UCLIBC_NG=y
CT_UCLIBC_NG_V_1_0_57=y
CT_GCC_USE_LINARO=y
CT_CC_LANG_CXX=y
CT_TOOLCHAIN_PKGVERSION="Linaro GCC 2019.12"
CT_TARGET_CFLAGS="-O2 -pipe -ftree-vectorize -fomit-frame-pointer -ffunction-sections -fdata-sections -mfloat-abi=hard"
CT_TARGET_LDFLAGS="-Wl,--gc-sections -Wl,-O1 -Wl,--as-needed -s -w"
# CT_SHOW_CT_VERSION is not set yet
