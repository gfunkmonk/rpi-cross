CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="/opt/x-tools/${CT_TARGET}"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARCH="armv6j"
CT_ARCH_CPU="arm1136jf-s"
CT_ARCH_TUNE="arm1136jf-s"
CT_ARCH_FPU="vfp"
CT_ARCH_ARM=y
CT_ARCH_SUFFIX="v6"
CT_TARGET_VENDOR="kindle"
# CT_ARCH_FLOAT_HW is not set
CT_ARCH_FLOAT_SOFTFP=y
#CT_ARCH_FLOAT_SW is not set
CT_ARCH_FLOAT="softfp"
CT_KERNEL_LINUX=y
CT_LINUX_V_2_6_32=y
CT_BINUTILS_PLUGINS=y
CT_BINUTILS_FOR_TARGET=y
CT_LIBC_GLIB=y
CT_GLIBC_V_2_9=y
CT_GCC_USE_LINARO=y
CT_GCC_LINARO_V_4_9=y
CT_CC_LANG_CXX=y
# CT_LINKER_MOLD is not set
CT_BINUTILS_V_2_26=y
CT_TOOLCHAIN_PKGVERSION="Amazon Kindle - Linaro GCC"
CT_TARGET_CFLAGS="-O2 -pipe -ftree-vectorize -fomit-frame-pointer -mno-unaligned-access -ffunction-sections -fdata-sections -marm -fno-stack-protector -U_FORTIFY_SOURCE -mfloat-abi=softfp -mfpu=vfp"
CT_TARGET_LDFLAGS="-Wl,--gc-sections -Wl,-O1 -Wl,--as-needed -s -w"