CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="/opt/x-tools/${CT_TARGET}"
# CT_LOG_PROGRESS_BAR is not set
CT_TARGET_VENDOR="pico"
CT_ARCH_ARM=y
CT_ARCH_ARCH="armv6s-m"	
CT_ARCH_CPU="cortex-m0plus"
CT_ARCH_TUNE="cortex-m0plus"
CT_ARCH_SUFFIX="v6m"
CT_ARCH_32=y
# CT_ARCH_64 is not set
CT_ARCH_FPU=""
CT_ARCH_FLOAT_AUTO=y
# CT_ARCH_FLOAT_HW is not set
# CT_ARCH_FLOAT_SOFTFP is not set
# CT_ARCH_FLOAT_SW is not set
CT_ARCH_FLOAT="auto"
CT_ARCH_ARM_MODE="thumb"
# CT_ARCH_ARM_MODE_ARM is not set
CT_ARCH_ARM_MODE_THUMB=y
CT_BARE_METAL=y
CT_KERNEL_BARE_METAL=y	
CT_BINUTILS_PLUGINS=y
CT_LIBC_PICOLIBC=y
CT_PICOLIBC_V_1_8=y
CT_LIBC_PICOLIBC_NANO_MALLOC=n
CT_CC_LANG_CXX=y
# CT_LINKER_MOLD is not set
CT_GCC_V_15=y
# CT_CC_GCC_ENABLE_DEFAULT_PIE is not set
CT_BINUTILS_V_2_46=y
CT_TOOLCHAIN_PKGVERSION="Raspberry Pi"
CT_TARGET_CFLAGS="-O2 -pipe -mthumb -ffixed-r9"
CT_TARGET_LDFLAGS="-s -w"
