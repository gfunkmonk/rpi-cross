#!/bin/bash

set -e
set -o pipefail

if [[ $# -lt 1 || -z "$1" ]]; then
    echo "Usage: $0 <target>" >&2
    echo "Example: $0 aarch64-rpi5-linux-gnu" >&2
    exit 1
fi

TARGET=$1
if [[ ! -d "targets/${TARGET}" ]]; then
    echo "Error: target '${TARGET}' not found in targets/" >&2
    exit 1
fi

# Enable Kitware repo
test -f /usr/share/keyrings/kitware-archive-keyring.gpg || { wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc 2>/dev/null | gpg --dearmor | sudo tee /usr/share/keyrings/kitware-archive-keyring.gpg >/dev/null; }
echo 'deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ noble main' | sudo tee /etc/apt/sources.list.d/kitware.list >/dev/null

# packages
export DEBIAN_FRONTEND=noninteractive
sudo apt-get update -qy && sudo apt-get install -y  \
  --no-install-recommends automake build-essential  \
  bzip2 cmake curl bison flex gawk gdb git gperf    \
  help2man libncurses-dev libssl-dev libtool-bin    \
  libzstd-dev pkg-config python3 rsync texinfo      \
  unzip wget xz-utils

# patch
pushd builder
git reset --hard HEAD
git clean -fd
shopt -s nullglob
for i in ../targets/"${TARGET}"/*.patch; do
    patch -Np1 -i "$i"
done
shopt -u nullglob
popd

# crosstool-ng
sudo mkdir -p /opt
sudo chown 0777 /opt
sudo rm -rf /opt/ct-ng
pushd builder
./bootstrap
./configure --prefix=/opt/ct-ng
make -j"$(nproc)"
sudo make install
popd

# build
rm -rf build
mkdir -p build
cp targets/"${TARGET}"/config build/.config

# Configure tarballs directory for download caching
echo 'CT_LOCAL_TARBALLS_DIR="/mnt/tarballs"' >> build/.config
echo 'CT_SAVE_TARBALLS=y' >> build/.config

pushd build
/opt/ct-ng/bin/ct-ng olddefconfig
/opt/ct-ng/bin/ct-ng build."$(nproc)"
popd

# Emit CMake + Meson cross files into the prefix before we tar it up.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
"${SCRIPT_DIR}/lib/emit-toolchain-files.sh" \
    "${TARGET}" "/opt/x-tools/${TARGET}" "targets/${TARGET}/config"

# Smoke-test: hello-world must compile and produce a binary of the
# expected architecture/ABI. Cheap gate that catches CFLAGS/config
# regressions before we spend minutes tarring.
"${SCRIPT_DIR}/lib/sanity-compile.sh" "${TARGET}" "/opt/x-tools/${TARGET}"

# tarball
sudo mv /opt/x-tools/"${TARGET}" .
sudo chown -R root:root "${TARGET}"
sudo tar --sort=name --owner=0 --group=0 --numeric-owner \
    -I 'xz -T0 -9' -cvf "${TARGET}".tar.xz "${TARGET}"
sha256sum "${TARGET}".tar.xz > "${TARGET}".tar.xz.sha256
