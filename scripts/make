#!/bin/bash

set -e
set -o pipefail

RED="\033[31;1m"
GREEN="\033[32;1m"
YELLOW="\033[33;1m"
BLUE="\033[34;1m"
PURPLE="\033[35;1m"
CYAN="\033[36;1m"
WHITE="\033[37;1m"
BLACK="\033[30;0m"
NC="\033[0m"

if [[ $# -lt 1 || -z "$1" ]]; then
    echo -e "${WHITE}Usage: $0 <target>${NC}" >&2
    echo -e "${BLUE}Example: $0 aarch64-rpi5-linux-gnu${NC}" >&2
    exit 1
fi

TARGET=$1
if [[ ! -d "targets/${TARGET}" ]]; then
    echo -e "${RED}Error: target '${TARGET}' not found in targets/${NC}" >&2
    exit 1
fi

# Enable Kitware repo
test -f /usr/share/keyrings/kitware-archive-keyring.gpg || { wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc 2>/dev/null | gpg --dearmor | sudo tee /usr/share/keyrings/kitware-archive-keyring.gpg >/dev/null; }
echo 'deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ noble main' | sudo tee /etc/apt/sources.list.d/kitware.list >/dev/null

# packages
export DEBIAN_FRONTEND=noninteractive
PACKAGES=(
    automake bison build-essential bzip2 cmake curl
    flex gawk gdb git gperf help2man libncurses-dev
    libssl-dev libtool-bin libzstd-dev meson ninja-build
    pkg-config python3 rsync texinfo unzip wget xz-utils
)

sudo -E apt-get update -qy
sudo -E apt-get install -y --no-install-recommends "${PACKAGES[@]}"

# patch
pushd builder
git reset --hard HEAD
git clean -fd
shopt -s nullglob
for i in ../targets/"${TARGET}"/*.patch; do
    patch -Np1 -i "$i"
done
shopt -u nullglob
popd

# crosstool-ng
sudo mkdir -p /opt
sudo chown 0777 /opt
sudo rm -rf /opt/ct-ng
pushd builder
./bootstrap
./configure --prefix=/opt/ct-ng
make -j"$(nproc)"
sudo make install
export CT_BIN="/opt/ct-ng/bin/ct-ng"
popd

# build
rm -rf build
mkdir -p build
cp targets/"${TARGET}"/config build/.config

# Configure tarballs directory for download caching
echo 'CT_LOCAL_TARBALLS_DIR="/mnt/tarballs"' >>build/.config
echo 'CT_SAVE_TARBALLS=y' >>build/.config

pushd build
"${CT_BIN}" olddefconfig
"${CT_BIN}" build."$(nproc)"
popd

# Emit CMake   Meson cross files into the prefix before we tar it up.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
"${SCRIPT_DIR}/lib/emit-toolchain-files.sh" "${TARGET}" "/opt/x-tools/${TARGET}" "targets/${TARGET}/config"

# Smoke-test: hello-world must compile and produce a binary of the
# expected architecture/ABI. Cheap gate that catches CFLAGS/config
# regressions before we spend minutes tarring.
"${SCRIPT_DIR}/lib/sanity-compile.sh" "${TARGET}" "/opt/x-tools/${TARGET}"

# Copying toolchain to PWD
sudo mv /opt/x-tools/"${TARGET}" .
sudo chown -R "$(id -u):$(id -g)" "${TARGET}"
sudo chmod -R u+rwX "${TARGET}"

p="$(pwd)/${TARGET}"
while [ "$p" != "/" ] && [ -n "$p" ]; do
  p="$(dirname "$p")"
  sudo chmod u+x "$p" 2>/dev/null || true
done

# Linaro toolchains land with an outer ${TARGET} alias dir wrapping a real
# crosstool-ng tuple dir, and gcc's hardcoded "<prefix>/<triple>/..." probes
# need two symlinks to line up:
#   1. ${TARGET}/${TARGET}                -> ${REAL_TARGET}
#   2. ${TARGET}/${REAL_TARGET}/bin/ld.gold -> mold    (naked/relative)
# Non-linaro targets have no arm-linaro-*/ subdir and fall through as a no-op.
linaro_hack() {
    local target=$1
    local real_target='' real_bin d prev_nullglob
    prev_nullglob=$(shopt -p nullglob || true)
    shopt -s nullglob
    for d in "${target}"/arm-linaro-*/; do
        real_target=${d#"${target}"/}
        real_target=${real_target%/}
        break
    done
    eval "$prev_nullglob"

    # das hinterhältig
    if [ -z "$real_target" ]; then
        echo -e "${GREEN}[INFO] linker hack: no arm-linaro-*/ dir under ${target}/, skipping${NC}"
        return 0
    fi

    real_bin=${target}/${real_target}/bin

    echo -e "${PURPLE}[INFO] linaro hack: linking ${target}/${target} -> ${real_target}${NC}"
    ( cd "$target" && sudo ln -snf "$real_target" "$target" )

    # the old sneaky pete
    if [ ! -d "$real_bin" ]; then
        echo -e "${YELLOW}[SKIP] linaro hack: no ${real_bin} dir, skipping mold->ld.gold${NC}"
        return 0
    fi

    echo "${BLUE}Doing the mold to gold switch-a-roo${NC}"
    if [ ! -f "${real_bin}/mold" ]; then
        echo -e "${RED}[ERROR] mold binary not found in ${real_bin}"
        return 0
    fi
    ( cd "$real_bin" && sudo ln -sf mold ld.gold )
    echo -e "${PURPLE}[SUCCESS] Internal ld.gold -> mold link secured in ${real_bin}${NC}"
}

linaro_hack "$TARGET"

# tarball
sudo tar --sort=name --owner=0 --group=0 --numeric-owner -I 'xz -T0 -9' -cvf "${TARGET}".tar.xz "${TARGET}"
sha256sum "${TARGET}".tar.xz >"${TARGET}".tar.xz.sha256
